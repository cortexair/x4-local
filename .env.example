# Database — local Postgres via Docker (docker-compose up)
DATABASE_URL=postgresql://fantasy:fantasy@localhost:5435/fantasy

# Authentication — secret for token signing (min 32 chars)
JWT_SECRET=local-dev-jwt-secret-change-in-production-32c
BETTER_AUTH_SECRET=local-dev-auth-secret-change-in-production-32c
BETTER_AUTH_URL=http://localhost:3002

# AI — Claude API key (optional for local dev without AI features)
# ANTHROPIC_API_KEY=sk-your-anthropic-api-key

# API server port (default: 3002)
PORT=3002

# Web app URL for CORS (default: http://localhost:3000)
WEB_URL=http://localhost:3000

# Marketing site URL for CORS (default: http://localhost:3001)
MARKETING_URL=http://localhost:3001

# Docs site URL for CORS (default: http://localhost:3003)
DOCS_URL=http://localhost:3003

# Environment
NODE_ENV=development

# App version
APP_VERSION=0.0.0

# Redis — optional, Upstash-compatible. If unset, cache and rate-limiting are disabled (fail-open).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# OAuth — optional social login providers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
