# Database — local Postgres via Docker (docker-compose up)
DATABASE_URL=postgresql://fantasy:fantasy@localhost:5435/fantasy

# Auth — Secret for signing tokens (min 32 characters)
JWT_SECRET=local-dev-jwt-secret-change-in-production-32c
BETTER_AUTH_SECRET=local-dev-auth-secret-change-in-production-32c
BETTER_AUTH_URL=http://localhost:3002

# OAuth — Social login providers (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# AI — Anthropic API key (optional for local dev without AI features)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Server
PORT=3002
NODE_ENV=development

# CORS origins
WEB_URL=http://localhost:3000
MARKETING_URL=http://localhost:3001

# Redis — optional, Upstash-compatible. If unset, cache and rate-limiting are disabled (fail-open).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional
# APP_VERSION=0.0.0
